<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ResourceDictionary.MergedDictionaries>
    <ResourceInclude Source="/Themes/Tokens.axaml"/>
  </ResourceDictionary.MergedDictionaries>

  <!-- CubicOdysseyVault dark palette (mirrors OpenFATX; accent kept red for now,
       can be retoned in a later phase to differentiate). -->
  <Color x:Key="MainBackground">#FF2D2D30</Color>
  <Color x:Key="SidebarBackground">#FF252526</Color>
  <Color x:Key="SidebarBlock">#FF3F3F46</Color>
  <Color x:Key="SidebarHeader">#FF2D2D30</Color>
  <Color x:Key="AccentColor">#FFC62828</Color>
  <Color x:Key="AccentColorSecondary">#FFE53935</Color>
  <Color x:Key="TextPrimary">#FFFFFFFF</Color>
  <Color x:Key="TextSecondary">#FF989898</Color>
  <Color x:Key="ActionHover">#FF3F3F41</Color>
  <Color x:Key="Separator">#FF46464A</Color>

  <!-- Status colors for slot health badges -->
  <Color x:Key="HealthHealthy">#FF4CAF50</Color>
  <Color x:Key="HealthSuspicious">#FFFFB300</Color>
  <Color x:Key="HealthCorrupted">#FFE53935</Color>

  <!-- Inventory category badges -->
  <Color x:Key="CategoryEquipment">#FF4CAF50</Color>
  <Color x:Key="CategoryWeapon">#FFE53935</Color>
  <Color x:Key="CategoryResource">#FF42A5F5</Color>
  <Color x:Key="CategoryShipComponent">#FFFFA726</Color>
  <Color x:Key="CategoryDeployable">#FFAB47BC</Color>
  <Color x:Key="CategoryKey">#FFFFD54F</Color>
  <Color x:Key="CategoryShip">#FF26C6DA</Color>
  <Color x:Key="CategoryOther">#FF757575</Color>

  <!-- Brushes -->
  <SolidColorBrush x:Key="MainBackgroundBrush" Color="{StaticResource MainBackground}" />
  <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackground}" />
  <SolidColorBrush x:Key="SidebarBlockBrush" Color="{StaticResource SidebarBlock}" />
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
  <SolidColorBrush x:Key="AccentBrushSecondary" Color="{StaticResource AccentColorSecondary}" />
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
  <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource Separator}" />
  <SolidColorBrush x:Key="HealthHealthyBrush" Color="{StaticResource HealthHealthy}" />
  <SolidColorBrush x:Key="HealthSuspiciousBrush" Color="{StaticResource HealthSuspicious}" />
  <SolidColorBrush x:Key="HealthCorruptedBrush" Color="{StaticResource HealthCorrupted}" />
  <SolidColorBrush x:Key="CategoryEquipmentBrush" Color="{StaticResource CategoryEquipment}" />
  <SolidColorBrush x:Key="CategoryWeaponBrush" Color="{StaticResource CategoryWeapon}" />
  <SolidColorBrush x:Key="CategoryResourceBrush" Color="{StaticResource CategoryResource}" />
  <SolidColorBrush x:Key="CategoryShipComponentBrush" Color="{StaticResource CategoryShipComponent}" />
  <SolidColorBrush x:Key="CategoryDeployableBrush" Color="{StaticResource CategoryDeployable}" />
  <SolidColorBrush x:Key="CategoryKeyBrush" Color="{StaticResource CategoryKey}" />
  <SolidColorBrush x:Key="CategoryShipBrush" Color="{StaticResource CategoryShip}" />
  <SolidColorBrush x:Key="CategoryOtherBrush" Color="{StaticResource CategoryOther}" />

</ResourceDictionary>
