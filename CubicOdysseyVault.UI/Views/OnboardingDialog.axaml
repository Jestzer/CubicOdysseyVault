<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CubicOdysseyVault.UI.ViewModels"
        x:Class="CubicOdysseyVault.UI.Views.OnboardingDialog"
        x:DataType="vm:OnboardingViewModel"
        Title="Welcome to Cubic Odyssey Vault"
        Icon="/Assets/icon.png"
        Width="640" Height="620"
        MinWidth="600" MinHeight="560"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource MainBackgroundBrush}">

    <DockPanel Margin="24">
        <!-- Buttons (bottom) -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        Spacing="{StaticResource SpaceSm}">
                <Button Classes="secondary"
                        Content="Cancel"
                        MinWidth="90"
                        Command="{Binding CancelCommand}" />
                <Button Classes="secondary"
                        Content="Back"
                        MinWidth="90"
                        Command="{Binding BackCommand}"
                        IsVisible="{Binding IsStep2}" />
                <Button Classes="primary"
                        Content="Next"
                        MinWidth="90"
                        Command="{Binding NextCommand}"
                        IsVisible="{Binding IsStep1}" />
                <Button Classes="primary"
                        Content="Get started"
                        MinWidth="120"
                        Command="{Binding FinishCommand}"
                        IsVisible="{Binding IsStep2}" />
            </StackPanel>
            <TextBlock Classes="body-sm"
                       VerticalAlignment="Center">
                <Run Text="Step "/>
                <Run Text="{Binding CurrentStep}"/>
                <Run Text=" of 2"/>
            </TextBlock>
        </DockPanel>

        <!-- Step 1: Welcome + detected sources -->
        <StackPanel IsVisible="{Binding IsStep1}" Spacing="{StaticResource SpaceLg}">
            <TextBlock Classes="display"
                       Text="Welcome to Cubic Odyssey Vault" />

            <StackPanel Spacing="10">
                <TextBlock Classes="body"
                           TextWrapping="Wrap">
                    Cubic Odyssey writes saves in place. A crash, a botched Quit, or a Cloud sync
                    glitch can zero them out — and the game keeps only ~20 slots before older
                    saves get overwritten.
                </TextBlock>
                <TextBlock Classes="body"
                           TextWrapping="Wrap">
                    This tool snapshots your saves on demand or automatically, keeps a history
                    you can browse, and lets you restore any point cleanly. Manual and tagged
                    snapshots are kept forever; auto snapshots are pruned by tier.
                </TextBlock>
            </StackPanel>

            <Border Classes="card"
                    Padding="{StaticResource PadLg}">
                <StackPanel Spacing="6">
                    <TextBlock Classes="label"
                               Text="WHAT WE FOUND ON THIS MACHINE" />
                    <TextBlock Classes="body"
                               Text="{Binding DetectedSummary}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock Classes="body-sm"
                       TextWrapping="Wrap">
                Click Next to choose a backup folder and tune defaults. You can always change
                these later from the Settings button in the toolbar.
            </TextBlock>
        </StackPanel>

        <!-- Step 2: Configuration form -->
        <ScrollViewer IsVisible="{Binding IsStep2}" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="{StaticResource SpaceLg}" DataContext="{Binding SettingsForm}" x:DataType="vm:SettingsViewModel">
                <TextBlock Classes="display"
                           Text="Configure your vault" />

                <StackPanel Spacing="6">
                    <TextBlock Classes="label" Text="BACKUP ROOT" />
                    <TextBlock Classes="body-sm"
                               Text="Snapshots are written here. We've suggested a folder under your local app data."
                               TextWrapping="Wrap" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Classes="secondary"
                                Content="Browse..."
                                MinWidth="90"
                                Margin="8,0,0,0"
                                Command="{Binding BrowseBackupRootCommand}" />
                        <TextBox Text="{Binding BackupRootPath}" />
                    </DockPanel>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Classes="label" Text="AUTOMATIC BACKUPS" />
                    <CheckBox Content="Watch save folders and snapshot on change"
                              IsChecked="{Binding WatcherEnabled}"
                              Foreground="{StaticResource TextPrimaryBrush}" />
                    <DockPanel IsEnabled="{Binding WatcherEnabled}">
                        <TextBlock DockPanel.Dock="Left"
                                   Classes="body"
                                   Text="Debounce window (seconds):"
                                   VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding WatcherDebounceSeconds}"
                                       Minimum="1" Maximum="300"
                                       FormatString="0"
                                       Width="120"
                                       Margin="12,0,0,0"
                                       HorizontalAlignment="Left" />
                    </DockPanel>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Classes="label" Text="RETENTION" />
                    <TextBlock Classes="body-sm"
                               Text="Auto snapshots are pruned to these counts per tier. Manual + tagged snapshots are kept forever."
                               TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,8,Auto,8,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="body" Text="Hourly:"
                                   VerticalAlignment="Center" />
                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                       Value="{Binding HourlySnapshotsKept}"
                                       Minimum="0" Maximum="999"
                                       FormatString="0"
                                       Width="120" HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="body" Text="Daily:"
                                   VerticalAlignment="Center" />
                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                       Value="{Binding DailySnapshotsKept}"
                                       Minimum="0" Maximum="999"
                                       FormatString="0"
                                       Width="120" HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Classes="body" Text="Weekly:"
                                   VerticalAlignment="Center" />
                        <NumericUpDown Grid.Row="4" Grid.Column="1"
                                       Value="{Binding WeeklySnapshotsKept}"
                                       Minimum="0" Maximum="999"
                                       FormatString="0"
                                       Width="120" HorizontalAlignment="Left" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
