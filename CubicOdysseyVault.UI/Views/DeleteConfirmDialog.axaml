<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CubicOdysseyVault.UI.ViewModels"
        x:Class="CubicOdysseyVault.UI.Views.DeleteConfirmDialog"
        x:DataType="vm:DeleteConfirmViewModel"
        Title="Delete snapshot"
        Icon="/Assets/icon.png"
        Width="460" Height="300"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource MainBackgroundBrush}">

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button Classes="secondary" Content="Cancel" MinWidth="80" Command="{Binding CancelCommand}" />
            <Button Classes="destructive"
                    Content="Delete"
                    MinWidth="80"
                    Command="{Binding ConfirmCommand}" />
        </StackPanel>

        <StackPanel Spacing="10">
            <TextBlock Classes="heading"
                       Text="Delete this snapshot?" />

            <Border Classes="card" Padding="{StaticResource PadLg}">
                <StackPanel Spacing="4">
                    <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,4,Auto,4,Auto,4,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="CAPTURED" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Classes="body" Text="{Binding CapturedAtText}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="TRIGGER" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Classes="body" Text="{Binding TriggerLabel}" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="SIZE" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Classes="numeric" Text="{Binding FormattedSize}" />
                        <TextBlock Grid.Row="6" Grid.Column="0" Classes="label" Text="TAG"
                                   IsVisible="{Binding IsTagged}" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Classes="body" Text="{Binding Tag}"
                                   Foreground="{StaticResource AccentBrush}" FontStyle="Italic"
                                   IsVisible="{Binding IsTagged}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card" Padding="{StaticResource PadMd}"
                    IsVisible="{Binding IsPreRestore}">
                <StackPanel Spacing="6">
                    <Border Classes="pill health-sus" HorizontalAlignment="Left">
                        <TextBlock Text="PRE-RESTORE"/>
                    </Border>
                    <TextBlock Classes="body-sm"
                               TextWrapping="Wrap"
                               Text="This is a Pre-restore snapshot — the only undo for the most recent restore. Deleting it makes that restore irreversible." />
                </StackPanel>
            </Border>

            <Border Classes="card" Padding="{StaticResource PadMd}"
                    IsVisible="{Binding IsTagged}">
                <StackPanel Spacing="6">
                    <Border Classes="pill health-sus" HorizontalAlignment="Left">
                        <TextBlock Text="TAGGED"/>
                    </Border>
                    <TextBlock Classes="body-sm"
                               TextWrapping="Wrap"
                               Text="This snapshot is tagged. Deleting removes the tag along with the snapshot." />
                </StackPanel>
            </Border>

            <TextBlock Classes="body"
                       TextWrapping="Wrap"
                       Text="The snapshot folder and its manifest entry will be removed. This cannot be undone." />
        </StackPanel>
    </DockPanel>
</Window>
