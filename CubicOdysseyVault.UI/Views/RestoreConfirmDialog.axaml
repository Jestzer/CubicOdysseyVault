<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CubicOdysseyVault.UI.ViewModels"
        x:Class="CubicOdysseyVault.UI.Views.RestoreConfirmDialog"
        x:DataType="vm:RestoreConfirmViewModel"
        Title="Restore snapshot"
        Icon="/Assets/icon.png"
        Width="540" Height="600"
        MinWidth="500" MinHeight="540"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource MainBackgroundBrush}">

    <DockPanel Margin="20">
        <!-- Buttons (bottom) -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button Classes="secondary" Content="Cancel" MinWidth="90" Command="{Binding CancelCommand}" />
            <Button Classes="primary"
                    Content="Restore"
                    MinWidth="90"
                    Command="{Binding ConfirmRestoreCommand}"
                    IsEnabled="{Binding CanRestore}" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14">
                <TextBlock Classes="label"
                           Text="{Binding SlotHeader}" />
                <TextBlock Classes="heading"
                           Text="Restore this snapshot?" />

                <Border CornerRadius="{StaticResource RadiusLg}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1"
                        ClipToBounds="True"
                        BoxShadow="0 4 14 #80000000"
                        IsVisible="{Binding HasScreenshot}">
                    <Image Source="{Binding Screenshot}"
                           Stretch="Uniform"
                           MaxHeight="220" />
                </Border>

                <Border Classes="card" Padding="{StaticResource PadMd}">
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,4,Auto,4,Auto,4,Auto,4,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="CAPTURED" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Classes="body-sm" Text="{Binding CapturedAtText}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="TRIGGER" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Classes="body-sm" Text="{Binding TriggerLabel}" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="SOURCE" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Classes="body-sm" Text="{Binding SourceLabel}" />
                            <TextBlock Grid.Row="6" Grid.Column="0" Classes="label" Text="CONTENTS" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Classes="body-sm">
                                <Run Text="{Binding FileCount}" /><Run Text=" files · " /><Run Text="{Binding FormattedSize}" />
                            </TextBlock>
                            <TextBlock Grid.Row="8" Grid.Column="0" Classes="label" Text="TAG"
                                       IsVisible="{Binding Tag, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <TextBlock Grid.Row="8" Grid.Column="1" Classes="body-sm" Text="{Binding Tag}"
                                       Foreground="{StaticResource AccentBrush}" FontStyle="Italic"
                                       IsVisible="{Binding Tag, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Classes="body"
                           TextWrapping="Wrap"
                           Text="{Binding BodyText}"/>

                <Border Classes="card" Padding="{StaticResource PadMd}"
                        IsVisible="{Binding IsGameRunning}">
                    <StackPanel Spacing="6">
                        <Border Classes="pill health-sus" HorizontalAlignment="Left">
                            <TextBlock Text="GAME RUNNING"/>
                        </Border>
                        <TextBlock Classes="body-sm"
                                   Text="Cubic Odyssey is running. Restore is blocked while the game is open."
                                   TextWrapping="Wrap"/>
                        <Button Content="Re-check"
                                Command="{Binding RecheckGameCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
