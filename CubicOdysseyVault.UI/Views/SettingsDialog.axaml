<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CubicOdysseyVault.UI.ViewModels"
        x:Class="CubicOdysseyVault.UI.Views.SettingsDialog"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Icon="/Assets/icon.png"
        Width="560" Height="700"
        MinWidth="520" MinHeight="600"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource MainBackgroundBrush}">

    <DockPanel Margin="20">
        <!-- Buttons (bottom) -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button Content="Cancel" MinWidth="90" Command="{Binding CancelCommand}" />
            <Button Content="Save"   MinWidth="90" Command="{Binding SaveCommand}" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                <!-- Backup root -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Backup root"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="Snapshots are written here. Defaults to a folder under your local app data."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="Browse..."
                                MinWidth="90"
                                Margin="8,0,0,0"
                                Command="{Binding BrowseBackupRootCommand}" />
                        <TextBox Text="{Binding BackupRootPath}" />
                    </DockPanel>
                </StackPanel>

                <!-- Game install path -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Cubic Odyssey install"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="Path to the folder containing data/configs/items/ and data/sprites/icons.png. Used for friendly item titles and per-item icons in the save inspector. Leave blank to auto-discover under your Steam libraries."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="Browse..."
                                MinWidth="90"
                                Margin="8,0,0,0"
                                Command="{Binding BrowseGameInstallCommand}" />
                        <TextBox Text="{Binding GameInstallPath}"
                                 Watermark="(auto-discover)" />
                    </DockPanel>
                </StackPanel>

                <!-- Manual sources -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Manual save sources"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="Extra folders to scan for slots — useful for external drives or recovered backups."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <Border Background="{StaticResource SidebarBlockBrush}"
                            BorderBrush="{StaticResource SeparatorBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="0">
                        <ListBox Height="100"
                                 ItemsSource="{Binding ManualSourceRoots}"
                                 SelectedItem="{Binding SelectedManualRoot}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="12" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Add..." Command="{Binding AddManualRootCommand}" />
                        <Button Content="Remove"
                                Command="{Binding RemoveManualRootCommand}"
                                IsEnabled="{Binding SelectedManualRoot, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                </StackPanel>

                <!-- Watcher -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Automatic backups"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" FontWeight="SemiBold" />
                    <CheckBox Content="Watch save folders and snapshot on change"
                              IsChecked="{Binding WatcherEnabled}"
                              Foreground="{StaticResource TextPrimaryBrush}" />
                    <DockPanel IsEnabled="{Binding WatcherEnabled}">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Debounce window (seconds):"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding WatcherDebounceSeconds}"
                                       Minimum="1" Maximum="300"
                                       FormatString="0"
                                       Width="120"
                                       Margin="12,0,0,0"
                                       HorizontalAlignment="Left" />
                    </DockPanel>
                </StackPanel>

                <!-- Retention -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Retention"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="How many automatic snapshots to keep at each tier. Manual + tagged snapshots are kept forever."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,8,Auto,8,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Hourly:"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                       Value="{Binding HourlySnapshotsKept}"
                                       Minimum="0" Maximum="999"
                                       FormatString="0"
                                       Width="120" HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Daily:"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                       Value="{Binding DailySnapshotsKept}"
                                       Minimum="0" Maximum="999"
                                       FormatString="0"
                                       Width="120" HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Weekly:"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <NumericUpDown Grid.Row="4" Grid.Column="1"
                                       Value="{Binding WeeklySnapshotsKept}"
                                       Minimum="0" Maximum="999"
                                       FormatString="0"
                                       Width="120" HorizontalAlignment="Left" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
