<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CubicOdysseyVault.UI.ViewModels"
        x:Class="CubicOdysseyVault.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Cubic Odyssey Vault"
        Width="1280" Height="780"
        MinWidth="1000" MinHeight="600"
        Background="{StaticResource MainBackgroundBrush}">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Refresh"
                        Command="{Binding RefreshDiscoveryCommand}"
                        IsEnabled="{Binding !IsDiscovering}"
                        MinWidth="90" />
                <Button Content="Settings"
                        Command="{Binding OpenSettingsCommand}"
                        MinWidth="90" />
                <Button Content="Open backup folder"
                        Command="{Binding OpenBackupFolderCommand}"
                        MinWidth="150" />
                <TextBlock Text="Scanning..."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           IsVisible="{Binding IsDiscovering}" />
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" />
        </Border>

        <!-- Sidebar -->
        <Border DockPanel.Dock="Left"
                Width="240"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,0,1,0"
                Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Steam users"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <TextBlock DockPanel.Dock="Top"
                           Text="(none discovered)"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           Margin="0,0,0,8"
                           IsVisible="{Binding ShowEmptyState}" />
                <ListBox ItemsSource="{Binding SteamUsers}"
                         SelectedItem="{Binding SelectedSteamUser}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SteamUserViewModel">
                            <StackPanel Spacing="2" Margin="0,4">
                                <TextBlock Text="{Binding SteamId32}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11">
                                    <Run Text="{Binding SlotCount}" />
                                    <Run Text=" slots" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Detail panel (right; visible when slot is selected) -->
        <Border DockPanel.Dock="Right"
                Width="360"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="1,0,0,0"
                Padding="16"
                IsVisible="{Binding SelectedSlot, Converter={x:Static ObjectConverters.IsNotNull}}">
            <ScrollViewer DataContext="{Binding SelectedSlot}" x:DataType="vm:SaveSlotViewModel">
                <StackPanel Spacing="14">
                    <!-- Hero screenshot -->
                    <Border CornerRadius="4"
                            BorderBrush="{StaticResource SeparatorBrush}"
                            BorderThickness="1"
                            ClipToBounds="True"
                            Background="{StaticResource SidebarBackgroundBrush}">
                        <Image Source="{Binding Screenshot}"
                               Stretch="Uniform"
                               MaxHeight="180" />
                    </Border>

                    <StackPanel Spacing="2">
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" FontWeight="SemiBold">
                            <Run Text="SLOT "/><Run Text="{Binding SlotName}"/><Run Text=" / ACCT "/><Run Text="{Binding AccountFolderName}"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding SourceLabel}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold" />
                            <Border CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                                    Background="{StaticResource HealthHealthyBrush}"
                                    IsVisible="{Binding IsHealthHealthy}">
                                <TextBlock Text="HEALTHY" Foreground="White" FontSize="9" FontWeight="SemiBold" />
                            </Border>
                            <Border CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                                    Background="{StaticResource HealthSuspiciousBrush}"
                                    IsVisible="{Binding IsHealthSuspicious}">
                                <TextBlock Text="SUSPICIOUS" Foreground="Black" FontSize="9" FontWeight="SemiBold" />
                            </Border>
                            <Border CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                                    Background="{StaticResource HealthCorruptedBrush}"
                                    IsVisible="{Binding IsHealthCorrupted}">
                                <TextBlock Text="CORRUPTED" Foreground="White" FontSize="9" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                            <Run Text="{Binding FileCount}"/><Run Text=" files · "/><Run Text="{Binding FormattedSize}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding LastWriteText}"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                    </StackPanel>

                    <Button Content="Back up now"
                            Command="{Binding BackUpNowCommand}"
                            HorizontalAlignment="Stretch" />
                    <TextBlock Text="{Binding BackupStatus}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               IsVisible="{Binding BackupStatus, Converter={x:Static ObjectConverters.IsNotNull}}" />

                    <StackPanel Spacing="6">
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" FontWeight="SemiBold">
                            <Run Text="SNAPSHOT HISTORY ("/><Run Text="{Binding SnapshotCount}"/><Run Text=")"/>
                        </TextBlock>
                        <TextBlock Text="No snapshots yet. Click Back up now to create one."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding !SnapshotCount}" />
                        <ItemsControl ItemsSource="{Binding Snapshots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SnapshotViewModel">
                                    <Border Background="{StaticResource SidebarBlockBrush}"
                                            BorderBrush="{StaticResource SeparatorBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="10"
                                            Margin="0,0,0,6">
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                                <Border CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                                                        Background="{StaticResource AccentBrush}"
                                                        IsVisible="{Binding IsTriggerManual}">
                                                    <TextBlock Text="MANUAL" Foreground="White" FontSize="9" FontWeight="SemiBold" />
                                                </Border>
                                                <Border CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                                                        Background="{StaticResource HealthHealthyBrush}"
                                                        IsVisible="{Binding IsTriggerAuto}">
                                                    <TextBlock Text="AUTO" Foreground="White" FontSize="9" FontWeight="SemiBold" />
                                                </Border>
                                                <Border CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                                                        Background="{StaticResource HealthSuspiciousBrush}"
                                                        IsVisible="{Binding IsTriggerPreRestore}">
                                                    <TextBlock Text="PRE-RESTORE" Foreground="Black" FontSize="9" FontWeight="SemiBold" />
                                                </Border>
                                                <TextBlock Text="{Binding CapturedAtText}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                                                    Content="Restore"
                                                    VerticalAlignment="Center"
                                                    MinWidth="80"
                                                    Margin="6,0,0,0"
                                                    Command="{Binding RestoreCommand}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11"
                                                       Margin="0,4,0,0">
                                                <Run Text="{Binding FormattedSize}"/><Run Text=" · "/><Run Text="{Binding HealthLabel}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Row="2" Grid.Column="0"
                                                       Text="{Binding Tag}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="11" FontStyle="Italic"
                                                       IsVisible="{Binding Tag, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Center content -->
        <Grid Margin="20">
            <DockPanel>
                <ItemsControl DockPanel.Dock="Top"
                              ItemsSource="{Binding SelectedSteamUser.Accounts}"
                              Margin="0,0,0,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SaveAccountViewModel">
                            <Border Background="{StaticResource SidebarBlockBrush}"
                                    BorderBrush="{StaticResource SeparatorBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="14"
                                    Margin="0,0,0,4">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="3">
                                        <TextBlock Text="Account-level data"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="10" FontWeight="SemiBold" />
                                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="13">
                                            <Run Text="{Binding FileCount}"/><Run Text=" files · "/><Run Text="{Binding FormattedSize}"/><Run Text=" · "/><Run Text="{Binding SourceLabel}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                            <Run Text="{Binding LastWriteText}"/><Run Text=" · "/><Run Text="{Binding LastSnapshotText}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding BackupStatus}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="11"
                                                   IsVisible="{Binding BackupStatus, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Back up now"
                                            VerticalAlignment="Center"
                                            Command="{Binding BackUpNowCommand}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ListBox ItemsSource="{Binding SelectedSteamUser.Slots}"
                             SelectedItem="{Binding SelectedSlot}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:SaveSlotViewModel">
                                <Border Width="240" Height="232"
                                        Margin="0,0,12,12"
                                        Padding="12"
                                        Background="{StaticResource SidebarBlockBrush}"
                                        BorderBrush="{StaticResource SeparatorBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <DockPanel>
                                        <!-- Thumbnail (top), with health badge overlay -->
                                        <Grid DockPanel.Dock="Top" Height="92" Margin="0,0,0,6">
                                            <Border CornerRadius="3"
                                                    BorderBrush="{StaticResource SeparatorBrush}"
                                                    BorderThickness="1"
                                                    ClipToBounds="True"
                                                    Background="{StaticResource SidebarBackgroundBrush}">
                                                <Image Source="{Binding Screenshot}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <!-- Health dot, top-right -->
                                            <Ellipse Width="12" Height="12"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                                     Margin="0,4,4,0"
                                                     Stroke="{StaticResource SidebarBackgroundBrush}"
                                                     StrokeThickness="1.5"
                                                     Fill="{StaticResource HealthHealthyBrush}"
                                                     IsVisible="{Binding IsHealthHealthy}" />
                                            <Ellipse Width="12" Height="12"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                                     Margin="0,4,4,0"
                                                     Stroke="{StaticResource SidebarBackgroundBrush}"
                                                     StrokeThickness="1.5"
                                                     Fill="{StaticResource HealthSuspiciousBrush}"
                                                     IsVisible="{Binding IsHealthSuspicious}" />
                                            <Ellipse Width="12" Height="12"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                                     Margin="0,4,4,0"
                                                     Stroke="{StaticResource SidebarBackgroundBrush}"
                                                     StrokeThickness="1.5"
                                                     Fill="{StaticResource HealthCorruptedBrush}"
                                                     IsVisible="{Binding IsHealthCorrupted}" />
                                            <Ellipse Width="12" Height="12"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                                     Margin="0,4,4,0"
                                                     Stroke="{StaticResource SidebarBackgroundBrush}"
                                                     StrokeThickness="1.5"
                                                     Fill="{StaticResource TextSecondaryBrush}"
                                                     IsVisible="{Binding IsHealthUnchecked}" />
                                        </Grid>
                                        <Button DockPanel.Dock="Bottom"
                                                Content="Back up now"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,4,0,0"
                                                Command="{Binding BackUpNowCommand}" />
                                        <StackPanel Spacing="3">
                                            <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold">
                                                <Run Text="Slot "/><Run Text="{Binding SlotName}"/><Run Text=" / acct "/><Run Text="{Binding AccountFolderName}"/>
                                            </TextBlock>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11">
                                                <Run Text="{Binding FileCount}"/><Run Text=" files · "/><Run Text="{Binding FormattedSize}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding LastSnapshotText}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="10" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
