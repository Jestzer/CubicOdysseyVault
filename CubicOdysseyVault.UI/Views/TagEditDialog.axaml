<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CubicOdysseyVault.UI.ViewModels"
        x:Class="CubicOdysseyVault.UI.Views.TagEditDialog"
        x:DataType="vm:TagEditViewModel"
        Title="Edit tag"
        Icon="/Assets/icon.png"
        Width="440" Height="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource MainBackgroundBrush}">

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button Classes="secondary" Content="Cancel" MinWidth="80" Command="{Binding CancelCommand}" />
            <Button Classes="secondary" Content="Clear tag" MinWidth="90" Command="{Binding ClearCommand}" />
            <Button Classes="primary"
                    Content="Save"
                    MinWidth="80"
                    Command="{Binding SaveCommand}" />
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Classes="label"
                       Text="{Binding SnapshotLabel}" />
            <TextBlock Classes="heading"
                       Text="Tag this snapshot" />
            <TextBlock Classes="body-sm"
                       TextWrapping="Wrap"
                       Text="Tagged snapshots are kept forever, even Auto ones. Leave empty and click Save (or click Clear tag) to remove an existing tag." />
            <TextBox Text="{Binding TagValue}"
                     Watermark="e.g. before-boss-fight" />
        </StackPanel>
    </DockPanel>
</Window>
