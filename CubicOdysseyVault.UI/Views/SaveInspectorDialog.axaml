<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CubicOdysseyVault.UI.ViewModels"
        x:Class="CubicOdysseyVault.UI.Views.SaveInspectorDialog"
        x:DataType="vm:SaveInspectorViewModel"
        Title="Inspect save"
        Icon="/Assets/icon.png"
        Width="1200" Height="780"
        MinWidth="1000" MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource MainBackgroundBrush}">

    <Window.Resources>
        <!-- Shared between the left and right inventory columns. Pulled out into
             a resource so the two ItemsControls can stack containers independently
             (so a 2-item card doesn't get padded out to a 30-item card's height
             the way UniformGrid forced) without duplicating the row template. -->
        <DataTemplate x:Key="InventoryContainerCardTemplate"
                      x:DataType="vm:InventoryContainerViewModel">
            <Border Classes="card"
                    Padding="{StaticResource PadLg}"
                    Margin="0,0,0,12">
                <StackPanel Spacing="{StaticResource SpaceSm}">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Classes="title"
                                   Text="{Binding DisplayName}" />
                        <TextBlock Grid.Column="1"
                                   Classes="label"
                                   Text="{Binding Subtitle}"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:InventoryItemViewModel">
                                <Grid ColumnDefinitions="44,Auto,38,*,Auto" Margin="0,3">
                                    <!-- Always render the 40x40 cell. Show the sliced atlas image when
                                         HasIcon, otherwise a category-colored placeholder so rows have
                                         a consistent left-edge rhythm. -->
                                    <Border Grid.Column="0"
                                            Width="40" Height="40"
                                            Background="{StaticResource SidebarBackgroundBrush}"
                                            BorderBrush="{StaticResource SeparatorBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            ClipToBounds="True"
                                            HorizontalAlignment="Left">
                                        <Panel>
                                            <Image Source="{Binding IconBitmap}"
                                                   Stretch="Uniform"
                                                   IsVisible="{Binding HasIcon}"/>
                                            <Border IsVisible="{Binding !HasIcon}"
                                                    Background="{Binding CategoryBrush}"
                                                    Opacity="0.18"/>
                                            <TextBlock IsVisible="{Binding !HasIcon}"
                                                       Text="{Binding CategoryAbbreviation}"
                                                       Foreground="{Binding CategoryBrush}"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       LetterSpacing="0.5"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Panel>
                                    </Border>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Border Classes="pill cat-equipment"
                                                IsVisible="{Binding IsCatEquipment}">
                                            <TextBlock Text="{Binding CategoryAbbreviation}" />
                                        </Border>
                                        <Border Classes="pill cat-weapon"
                                                IsVisible="{Binding IsCatWeapon}">
                                            <TextBlock Text="{Binding CategoryAbbreviation}" />
                                        </Border>
                                        <Border Classes="pill cat-resource"
                                                IsVisible="{Binding IsCatResource}">
                                            <TextBlock Text="{Binding CategoryAbbreviation}" />
                                        </Border>
                                        <Border Classes="pill cat-shipcomponent"
                                                IsVisible="{Binding IsCatShipComponent}">
                                            <TextBlock Text="{Binding CategoryAbbreviation}" />
                                        </Border>
                                        <Border Classes="pill cat-deployable"
                                                IsVisible="{Binding IsCatDeployable}">
                                            <TextBlock Text="{Binding CategoryAbbreviation}" />
                                        </Border>
                                        <Border Classes="pill cat-key"
                                                IsVisible="{Binding IsCatKey}">
                                            <TextBlock Text="{Binding CategoryAbbreviation}" />
                                        </Border>
                                        <Border Classes="pill cat-ship"
                                                IsVisible="{Binding IsCatShip}">
                                            <TextBlock Text="{Binding CategoryAbbreviation}" />
                                        </Border>
                                        <Border Classes="pill cat-other"
                                                IsVisible="{Binding IsCatOther}">
                                            <TextBlock Text="{Binding CategoryAbbreviation}" />
                                        </Border>
                                    </StackPanel>
                                    <Border Grid.Column="2"
                                            BorderBrush="{StaticResource SeparatorBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="4,2"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            IsVisible="{Binding HasTier}">
                                        <TextBlock Text="{Binding TierText}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="10" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Grid.Column="3"
                                               Classes="body-sm"
                                               Text="{Binding DisplayName}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding DisplayName}"/>
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding CountText}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontFamily="Consolas,monospace"
                                               FontSize="12"
                                               MinWidth="40"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,8">
            <TextBlock Text="{Binding Title}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="13" FontWeight="SemiBold" />
        </Border>

        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom"
                Name="CloseBar"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Button Content="Close"
                    HorizontalAlignment="Right"
                    MinWidth="80"
                    Command="{Binding CloseCommand}" />
        </Border>

        <!-- Top-level tabs: Summary | Files -->
        <TabControl Background="Transparent" BorderThickness="0" Padding="0">

            <!-- ========== SUMMARY ========== -->
            <TabItem Header="Summary">
                <ScrollViewer Name="SummaryScrollViewer"
                              DataContext="{Binding Summary}"
                              x:DataType="vm:SaveSummaryViewModel">
                    <!-- Padding moved off the ScrollViewer onto the inner StackPanel as
                         Margin: ScrollViewer.Padding doesn't get reflected in Extent in
                         Avalonia 11.2.x, which leaves max-scroll short and lets the
                         last card overflow the visible viewport (the SHIPS-card-clipped-
                         behind-close-bar bug). Margin on the content does feed into
                         Extent correctly. -->
                    <StackPanel Spacing="{StaticResource SpaceLg}" Margin="24,24,24,24">
                        <!-- Character + timestamp -->
                        <Border Classes="card" Padding="{StaticResource PadLg}">
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="{StaticResource SpaceXs}">
                                    <TextBlock Classes="label" Text="CHARACTER" />
                                    <TextBlock Classes="display" Text="{Binding CharacterName}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="{StaticResource SpaceXs}" HorizontalAlignment="Right">
                                    <TextBlock Classes="label" Text="SAVED AT"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding SavedAtText}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14" FontFamily="Consolas,monospace" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Warnings -->
                        <Border Background="{StaticResource SidebarBlockBrush}"
                                BorderBrush="{StaticResource HealthSuspiciousBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{StaticResource PadMd}"
                                IsVisible="{Binding HasWarnings}">
                            <StackPanel Spacing="{StaticResource SpaceXs}">
                                <TextBlock Classes="label"
                                           Text="NOTES"
                                           Foreground="{StaticResource HealthSuspiciousBrush}" />
                                <ItemsControl ItemsSource="{Binding Warnings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Classes="body-sm"
                                                       Text="{Binding}"
                                                       Foreground="{StaticResource HealthSuspiciousBrush}"
                                                       TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Inventory containers — laid out in two independently-stacked
                             columns. Containers are pre-partitioned into Left/Right by
                             the view model (greedy fill by row count) so a small card
                             doesn't get padded out to the height of the largest one
                             the way UniformGrid forced. -->
                        <Grid IsVisible="{Binding HasInventories}"
                              ColumnDefinitions="*,12,*">
                            <ItemsControl Grid.Column="0"
                                          ItemsSource="{Binding LeftContainers}"
                                          ItemTemplate="{StaticResource InventoryContainerCardTemplate}" />
                            <ItemsControl Grid.Column="2"
                                          ItemsSource="{Binding RightContainers}"
                                          ItemTemplate="{StaticResource InventoryContainerCardTemplate}" />
                        </Grid>

                        <!-- Ships — each ship is a row with an isometric voxel
                             thumbnail (rendered from the ship_*.vx file by
                             VoxelRenderer), filename, dim, and block count. Wraps
                             across rows so multiple ships fit per scroll line. -->
                        <Border Name="ShipsCard"
                                Classes="card"
                                Padding="{StaticResource PadLg}"
                                IsVisible="{Binding HasShips}">
                            <StackPanel Spacing="{StaticResource SpaceSm}">
                                <TextBlock Classes="label" Text="SHIPS" />
                                <ItemsControl ItemsSource="{Binding Ships}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ShipPreviewViewModel">
                                            <Border Background="#0AFFFFFF"
                                                    BorderBrush="{StaticResource SeparatorBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="8"
                                                    Margin="0,4,8,0"
                                                    Width="220">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <Border Grid.Column="0"
                                                            Width="64" Height="64"
                                                            Background="{StaticResource SidebarBackgroundBrush}"
                                                            CornerRadius="3"
                                                            ClipToBounds="True"
                                                            Margin="0,0,10,0">
                                                        <Image Source="{Binding Thumbnail}"
                                                               Stretch="Uniform"
                                                               Width="64" Height="64"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1"
                                                                Spacing="2"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding FileName}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontFamily="Consolas,monospace"
                                                                   FontSize="12"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding DimensionsLabel}"
                                                                   Classes="caption"/>
                                                        <TextBlock Text="{Binding SolidCountLabel}"
                                                                   Classes="caption"/>
                                                        <TextBlock Text="{Binding MaterialsLabel}"
                                                                   Classes="caption"/>
                                                        <TextBlock Text="{Binding ErrorMessage}"
                                                                   Classes="caption"
                                                                   Foreground="{StaticResource HealthSuspiciousBrush}"
                                                                   IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ========== FILES ========== -->
            <TabItem Header="Files">
                <DockPanel>
                    <Border DockPanel.Dock="Left"
                            Width="260"
                            Background="{StaticResource SidebarBackgroundBrush}"
                            BorderBrush="{StaticResource SeparatorBrush}"
                            BorderThickness="0,0,1,0"
                            Padding="8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Classes="label"
                                       Text="FILES"
                                       Margin="4,0,0,8" />
                            <ListBox ItemsSource="{Binding Files}"
                                     SelectedItem="{Binding SelectedFile}"
                                     Background="{StaticResource SidebarBackgroundBrush}"
                                     BorderThickness="0">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                    </Style>
                                    <Style Selector="ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
                                        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                        <Setter Property="Background" Value="#0DFFFFFF"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                        <Setter Property="Background" Value="{DynamicResource AccentSurfaceBrush}"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SaveFileViewModel">
                                        <StackPanel Spacing="2" Margin="6,4">
                                            <TextBlock Classes="body"
                                                       Text="{Binding FileName}" />
                                            <TextBlock Classes="body-sm"
                                                       Text="{Binding SizeLabel}"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                    <Grid Margin="0">
                        <TextBlock Text="Select a file"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding !HasSelectedFile}" />
                        <ContentControl IsVisible="{Binding HasSelectedFile}"
                                        Content="{Binding SelectedFile}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate x:DataType="vm:SaveFileViewModel">
                                    <TabControl Background="Transparent" BorderThickness="0" Padding="{StaticResource PadMd}">
                                        <TabItem Header="Decoded">
                                            <DockPanel Margin="{StaticResource PadLg}">
                                                <TextBlock DockPanel.Dock="Top"
                                                           Classes="body-sm"
                                                           Text="{Binding ErrorMessage}"
                                                           Foreground="{StaticResource HealthSuspiciousBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,8"
                                                           IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                <TextBlock DockPanel.Dock="Top"
                                                           Classes="body-sm"
                                                           Text="Not a Cubic Odyssey TLV save (use Strings or Hex)."
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,8"
                                                           IsVisible="{Binding !IsTlvSave}" />
                                                <ScrollViewer IsVisible="{Binding IsTlvSave}">
                                                    <TreeView ItemsSource="{Binding TlvEntries}" Background="Transparent">
                                                        <TreeView.ItemTemplate>
                                                            <TreeDataTemplate ItemsSource="{Binding Children}"
                                                                              x:DataType="vm:TlvEntryViewModel">
                                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                                    <TextBlock Classes="label"
                                                                               Text="{Binding TagDisplay}"
                                                                               MinWidth="160" />
                                                                    <TextBlock Classes="label"
                                                                               Text="{Binding KindLabel}"
                                                                               MinWidth="60" />
                                                                    <TextBlock Classes="numeric"
                                                                               Text="{Binding ValueText}" />
                                                                    <TextBlock Classes="numeric"
                                                                               Text="{Binding HexPreview}"
                                                                               FontSize="10"
                                                                               VerticalAlignment="Center" />
                                                                </StackPanel>
                                                            </TreeDataTemplate>
                                                        </TreeView.ItemTemplate>
                                                    </TreeView>
                                                </ScrollViewer>
                                            </DockPanel>
                                        </TabItem>
                                        <TabItem Header="Strings">
                                            <ScrollViewer Margin="{StaticResource PadLg}">
                                                <ItemsControl ItemsSource="{Binding Strings}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid ColumnDefinitions="100,*" Margin="0,0,0,2">
                                                                <TextBlock Grid.Column="0"
                                                                           Classes="numeric"
                                                                           Text="{Binding Offset, StringFormat='@0x{0:x6}'}"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           FontSize="11" />
                                                                <TextBlock Grid.Column="1"
                                                                           Classes="numeric"
                                                                           Text="{Binding Text}"
                                                                           FontSize="12" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </TabItem>
                                        <TabItem Header="Hex">
                                            <ScrollViewer Margin="{StaticResource PadLg}" HorizontalScrollBarVisibility="Auto">
                                                <SelectableTextBlock Classes="numeric"
                                                                     Text="{Binding HexText}"
                                                                     FontFamily="Cascadia Mono, Consolas, monospace"
                                                                     FontSize="11" />
                                            </ScrollViewer>
                                        </TabItem>
                                    </TabControl>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </Grid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
