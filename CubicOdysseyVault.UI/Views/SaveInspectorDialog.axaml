<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CubicOdysseyVault.UI.ViewModels"
        x:Class="CubicOdysseyVault.UI.Views.SaveInspectorDialog"
        x:DataType="vm:SaveInspectorViewModel"
        Title="Inspect save"
        Icon="/Assets/icon.png"
        Width="1200" Height="780"
        MinWidth="1000" MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource MainBackgroundBrush}">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,8">
            <TextBlock Text="{Binding Title}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="13" FontWeight="SemiBold" />
        </Border>

        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Button Content="Close"
                    HorizontalAlignment="Right"
                    MinWidth="80"
                    Command="{Binding CloseCommand}" />
        </Border>

        <!-- Top-level tabs: Summary | Files -->
        <TabControl Background="Transparent" BorderThickness="0" Padding="0">

            <!-- ========== SUMMARY ========== -->
            <TabItem Header="Summary">
                <ScrollViewer Padding="{StaticResource PadXl}" DataContext="{Binding Summary}" x:DataType="vm:SaveSummaryViewModel">
                    <StackPanel Spacing="{StaticResource SpaceLg}" MaxWidth="900" HorizontalAlignment="Left">
                        <!-- Character + timestamp -->
                        <Border Classes="card" Padding="{StaticResource PadLg}">
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="{StaticResource SpaceXs}">
                                    <TextBlock Classes="label" Text="CHARACTER" />
                                    <TextBlock Classes="display" Text="{Binding CharacterName}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="{StaticResource SpaceXs}" HorizontalAlignment="Right">
                                    <TextBlock Classes="label" Text="SAVED AT"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding SavedAtText}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14" FontFamily="Consolas,monospace" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Warnings -->
                        <Border Background="{StaticResource SidebarBlockBrush}"
                                BorderBrush="{StaticResource HealthSuspiciousBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{StaticResource PadMd}"
                                IsVisible="{Binding HasWarnings}">
                            <StackPanel Spacing="{StaticResource SpaceXs}">
                                <TextBlock Classes="label"
                                           Text="NOTES"
                                           Foreground="{StaticResource HealthSuspiciousBrush}" />
                                <ItemsControl ItemsSource="{Binding Warnings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Classes="body-sm"
                                                       Text="{Binding}"
                                                       Foreground="{StaticResource HealthSuspiciousBrush}"
                                                       TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Inventory containers -->
                        <ItemsControl ItemsSource="{Binding Containers}"
                                      IsVisible="{Binding HasInventories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:InventoryContainerViewModel">
                                    <Border Classes="card"
                                            Padding="{StaticResource PadLg}"
                                            Margin="0,0,0,12">
                                        <StackPanel Spacing="{StaticResource SpaceSm}">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Classes="title"
                                                           Text="{Binding DisplayName}" />
                                                <TextBlock Grid.Column="1"
                                                           Classes="label"
                                                           Text="{Binding Subtitle}"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:InventoryItemViewModel">
                                                        <Grid ColumnDefinitions="44,Auto,38,*,Auto" Margin="0,3">
                                                            <Border Grid.Column="0"
                                                                    Width="40" Height="40"
                                                                    Background="{StaticResource SidebarBackgroundBrush}"
                                                                    BorderBrush="{StaticResource SeparatorBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="3"
                                                                    ClipToBounds="True"
                                                                    HorizontalAlignment="Left"
                                                                    IsVisible="{Binding HasIcon}">
                                                                <Image Source="{Binding IconBitmap}"
                                                                       Stretch="Uniform" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                <Border Classes="pill cat-equipment"
                                                                        IsVisible="{Binding IsCatEquipment}">
                                                                    <TextBlock Text="{Binding CategoryAbbreviation}" />
                                                                </Border>
                                                                <Border Classes="pill cat-weapon"
                                                                        IsVisible="{Binding IsCatWeapon}">
                                                                    <TextBlock Text="{Binding CategoryAbbreviation}" />
                                                                </Border>
                                                                <Border Classes="pill cat-resource"
                                                                        IsVisible="{Binding IsCatResource}">
                                                                    <TextBlock Text="{Binding CategoryAbbreviation}" />
                                                                </Border>
                                                                <Border Classes="pill cat-shipcomponent"
                                                                        IsVisible="{Binding IsCatShipComponent}">
                                                                    <TextBlock Text="{Binding CategoryAbbreviation}" />
                                                                </Border>
                                                                <Border Classes="pill cat-deployable"
                                                                        IsVisible="{Binding IsCatDeployable}">
                                                                    <TextBlock Text="{Binding CategoryAbbreviation}" />
                                                                </Border>
                                                                <Border Classes="pill cat-key"
                                                                        IsVisible="{Binding IsCatKey}">
                                                                    <TextBlock Text="{Binding CategoryAbbreviation}" />
                                                                </Border>
                                                                <Border Classes="pill cat-ship"
                                                                        IsVisible="{Binding IsCatShip}">
                                                                    <TextBlock Text="{Binding CategoryAbbreviation}" />
                                                                </Border>
                                                                <Border Classes="pill cat-other"
                                                                        IsVisible="{Binding IsCatOther}">
                                                                    <TextBlock Text="{Binding CategoryAbbreviation}" />
                                                                </Border>
                                                            </StackPanel>
                                                            <Border Grid.Column="2"
                                                                    BorderBrush="{StaticResource SeparatorBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="3"
                                                                    Padding="4,2"
                                                                    Margin="6,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Left"
                                                                    IsVisible="{Binding HasTier}">
                                                                <TextBlock Text="{Binding TierText}"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           FontSize="10" FontWeight="SemiBold" />
                                                            </Border>
                                                            <TextBlock Grid.Column="3"
                                                                       Classes="body-sm"
                                                                       Text="{Binding DisplayName}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="10,0,0,0"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Grid.Column="4"
                                                                       Text="{Binding CountText}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontFamily="Consolas,monospace"
                                                                       FontSize="12"
                                                                       MinWidth="40"
                                                                       TextAlignment="Right"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Ships -->
                        <Border Classes="card"
                                Padding="{StaticResource PadLg}"
                                IsVisible="{Binding HasShips}">
                            <StackPanel Spacing="{StaticResource SpaceSm}">
                                <TextBlock Classes="label" Text="SHIPS" />
                                <ItemsControl ItemsSource="{Binding Ships}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontFamily="Consolas,monospace"
                                                       FontSize="12"
                                                       Margin="0,2" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ========== FILES ========== -->
            <TabItem Header="Files">
                <DockPanel>
                    <Border DockPanel.Dock="Left"
                            Width="260"
                            Background="{StaticResource SidebarBackgroundBrush}"
                            BorderBrush="{StaticResource SeparatorBrush}"
                            BorderThickness="0,0,1,0"
                            Padding="8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Files"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Margin="4,0,0,8" />
                            <ListBox ItemsSource="{Binding Files}"
                                     SelectedItem="{Binding SelectedFile}"
                                     Background="Transparent"
                                     BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SaveFileViewModel">
                                        <StackPanel Spacing="2" Margin="0,2">
                                            <TextBlock Text="{Binding FileName}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontFamily="Consolas,monospace"
                                                       FontSize="12" />
                                            <TextBlock Text="{Binding SizeLabel}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="10" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                    <Grid Margin="0">
                        <TextBlock Text="Select a file"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding !HasSelectedFile}" />
                        <ContentControl IsVisible="{Binding HasSelectedFile}"
                                        Content="{Binding SelectedFile}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate x:DataType="vm:SaveFileViewModel">
                                    <TabControl Background="Transparent" BorderThickness="0" Padding="0">
                                        <TabItem Header="Decoded">
                                            <DockPanel Margin="14">
                                                <TextBlock DockPanel.Dock="Top"
                                                           Text="{Binding ErrorMessage}"
                                                           Foreground="{StaticResource HealthSuspiciousBrush}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,8"
                                                           IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                <TextBlock DockPanel.Dock="Top"
                                                           Text="Not a Cubic Odyssey TLV save (use Strings or Hex)."
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="11"
                                                           Margin="0,0,0,8"
                                                           IsVisible="{Binding !IsTlvSave}" />
                                                <ScrollViewer IsVisible="{Binding IsTlvSave}">
                                                    <TreeView ItemsSource="{Binding TlvEntries}" Background="Transparent">
                                                        <TreeView.ItemTemplate>
                                                            <TreeDataTemplate ItemsSource="{Binding Children}"
                                                                              x:DataType="vm:TlvEntryViewModel">
                                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                                    <TextBlock Text="{Binding TagDisplay}"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               FontWeight="SemiBold"
                                                                               MinWidth="160" />
                                                                    <TextBlock Text="{Binding KindLabel}"
                                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                                               FontSize="11"
                                                                               MinWidth="60" />
                                                                    <TextBlock Text="{Binding ValueText}"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               FontFamily="Consolas,monospace" />
                                                                    <TextBlock Text="{Binding HexPreview}"
                                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                                               FontFamily="Consolas,monospace"
                                                                               FontSize="10"
                                                                               VerticalAlignment="Center" />
                                                                </StackPanel>
                                                            </TreeDataTemplate>
                                                        </TreeView.ItemTemplate>
                                                    </TreeView>
                                                </ScrollViewer>
                                            </DockPanel>
                                        </TabItem>
                                        <TabItem Header="Strings">
                                            <ScrollViewer Margin="14">
                                                <ItemsControl ItemsSource="{Binding Strings}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid ColumnDefinitions="100,*" Margin="0,0,0,2">
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding Offset, StringFormat='@0x{0:x6}'}"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           FontFamily="Consolas,monospace"
                                                                           FontSize="11" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Text}"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontFamily="Consolas,monospace"
                                                                           FontSize="12" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </TabItem>
                                        <TabItem Header="Hex">
                                            <ScrollViewer Margin="14" HorizontalScrollBarVisibility="Auto">
                                                <SelectableTextBlock Text="{Binding HexText}"
                                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                                     FontFamily="Consolas,monospace"
                                                                     FontSize="11" />
                                            </ScrollViewer>
                                        </TabItem>
                                    </TabControl>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </Grid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
